{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cross-Debug EdgeSense (RPi5)",
            "type": "cppdbg",
            "request": "launch",
            "program": "/home/hedi/EdgeSenseApp",
            "args": [],
            "stopAtEntry": false,
            "cwd": "/home/hedi",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb-multiarch",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set sysroot for remote debugging",
                    "text": "set sysroot remote:/",
                    "ignoreFailures": false
                }
            ],
            "pipeTransport": {
                "pipeCwd": "${workspaceFolder}",
                "pipeProgram": "/usr/bin/ssh",
                "pipeArgs": [
                    "hedi@Hedi-RPi5.local"
                ],
                "debuggerPath": "/usr/bin/gdb"
            },
            "preLaunchTask": "Deploy to HediPi",
            "sourceFileMap": {
                "/media/hedi/Work/Linux/MyLinuxProject/Code/EdgeSense": "${workspaceFolder}"
            }
        },
        {
            "name": "Debug EdgeSense (Host)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/host/EdgeSenseApp",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake: build"
        }
    ]
}